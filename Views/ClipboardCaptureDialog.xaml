<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FxTradeConfirmation.Views.ClipboardCaptureDialog"
        Title="Option Request Captured" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource AccentBlueBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <Border.Resources>

            <!-- ── Dark context menu ── -->
            <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="#FF1A2138"/>
                <Setter Property="BorderBrush" Value="#FF2D3654"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="3"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Dark menu item ── -->
            <Style x:Key="DarkMenuItem" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#FFE2E8F0"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#FF252D4A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#FF2563EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Border.Resources>

        <StackPanel>

            <!-- ── Header (draggable) ── -->
            <DockPanel Margin="0,0,0,16" Background="Transparent"
                       MouseLeftButtonDown="Header_MouseLeftButtonDown"
                       Cursor="SizeAll">
                <Button Content="✕" DockPanel.Dock="Right"
                        Style="{StaticResource IconButton}"
                        Foreground="{StaticResource TextMutedBrush}"
                        Click="Reject_Click" ToolTip="Reject (Esc)"
                        VerticalAlignment="Top"/>
                <TextBlock Text="📋  Option Request Detected"
                           Style="{StaticResource FieldLabel}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- ── Parse status badge ── -->
            <Border x:Name="ParseStatusBorder"
                    CornerRadius="6" Padding="10,6" Margin="0,0,0,16"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="ParseStatusLabel"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11" FontWeight="SemiBold"/>
            </Border>

            <!-- ── Summary row: pair / expiry / spot ── -->
            <Border Background="{StaticResource BgDarkBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PAIR" Style="{StaticResource FieldLabel}"
                                   FontSize="9" Margin="0,0,0,3"/>
                        <TextBlock x:Name="PairLabel"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="EXPIRY" Style="{StaticResource FieldLabel}"
                                   FontSize="9" Margin="0,0,0,3"/>
                        <TextBlock x:Name="ExpiryLabel"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SPOT REF" Style="{StaticResource FieldLabel}"
                                   FontSize="9" Margin="0,0,0,3"/>
                        <TextBlock x:Name="SpotLabel"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningAmberBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Legs ── -->
            <TextBlock Text="LEGS" Style="{StaticResource FieldLabel}"
                       FontSize="9" Margin="0,0,0,6"/>
            <ItemsControl x:Name="LegsList" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgInputBrush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="12,10" Margin="0,0,0,6">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Leg number -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding LegNumber}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,2"/>

                                <!-- Buy / Sell -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="SIDE" FontSize="8"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <Button Content="{Binding BuySell}"
                                            Background="{Binding BuySellBrush}"
                                            Foreground="{StaticResource TextWhiteBrush}"
                                            BorderThickness="0"
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="11" FontWeight="Bold"
                                            Padding="6,3" Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            ToolTip="Click to toggle Buy / Sell"
                                            Tag="{Binding}"
                                            Click="ToggleBuySell_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- Call / Put -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="TYPE" FontSize="8"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <Button Content="{Binding PutCall}"
                                            Background="{Binding CallPutBrush}"
                                            Foreground="{StaticResource TextWhiteBrush}"
                                            BorderThickness="0"
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="11" FontWeight="Bold"
                                            Padding="6,3" Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            ToolTip="Click to toggle Call / Put"
                                            Tag="{Binding}"
                                            Click="ToggleCallPut_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- Strike -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="STRIKE" FontSize="8"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding Strike}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Notional -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="NOTIONAL" FontSize="8"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding NotionalDisplay}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Raw OVML string — högerklick → Copy ── -->
            <Border Background="{StaticResource BgDarkBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="10,8" Margin="0,0,0,20">
                <TextBlock x:Name="OvmlLabel"
                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           ToolTip="Right-click to copy OVML">
                    <TextBlock.ContextMenu>
                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                            <MenuItem Header="⎘  Copy OVML"
                                      Style="{StaticResource DarkMenuItem}"
                                      Click="OvmlCopy_Click"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </Border>

            <!-- ── Action buttons — equal width ── -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0" Padding="0,14,0,0">
                <UniformGrid Rows="1" Columns="4">

                    <!-- Reject — dämpad röd outline -->
                    <Button Content="✕  Reject"
                            Style="{StaticResource TradingButton}"
                            Background="#22EF4444"
                            BorderBrush="#99EF4444"
                            BorderThickness="1"
                            Foreground="#FFEF9090"
                            Click="Reject_Click" Margin="0,0,6,0"
                            ToolTip="Dismiss this request (Esc)">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#44EF4444"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FFEF4444"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#66EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>



                    <!-- Fill Form — ghost/muted -->
                    <Button x:Name="PopulateButton"
                            Content="✓  Fill Form"
                            Style="{StaticResource TradingButton}"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Click="Populate_Click" Margin="0,0,6,0"
                            ToolTip="Fill the trade form with parsed legs">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueMutedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Bloomberg — ghost/muted (identisk stil som Fill Form) -->
                    <Button x:Name="BloombergButton"
                            Content="📊  Bloomberg"
                            Style="{StaticResource TradingButton}"
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Click="Bloomberg_Click" Margin="0,0,6,0"
                            ToolTip="Open in Bloomberg Pricer only">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueMutedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Fill & Price — dämpad blå outline (primär men inte skrikig) -->
                    <Button x:Name="BothButton"
                            Content="⚡  Fill &amp; Price"
                            Style="{StaticResource TradingButton}"
                            Background="#223B82F6"
                            BorderBrush="#993B82F6"
                            BorderThickness="1"
                            Foreground="#FF93B4F8"
                            Padding="16,10"
                            FontSize="13"
                            Click="Both_Click"
                            ToolTip="Fill the trade form and open in Bloomberg Pricer">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#443B82F6"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FF3B82F6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#663B82F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </UniformGrid>
            </Border>

        </StackPanel>
    </Border>
</Window>