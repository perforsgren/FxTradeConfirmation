<UserControl x:Class="FxTradeConfirmation.Views.PayoffChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="240">

    <Border Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,12">
        <Canvas x:Name="ChartCanvas"
                ClipToBounds="True"
                SizeChanged="ChartCanvas_SizeChanged"/>
    </Border>
</UserControl>