<Window x:Class="FxTradeConfirmation.Views.WeekendRollDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weekend Expiry" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource WarningAmberBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel>

            <!-- Header -->
            <DockPanel Margin="0,0,0,16">
                <Button Content="✕" DockPanel.Dock="Right"
                        Style="{StaticResource IconButton}"
                        Foreground="{StaticResource TextMutedBrush}"
                        Click="Cancel_Click" ToolTip="Keep date (Esc)"
                        VerticalAlignment="Top"/>
                <TextBlock Text="⚠  Weekend Expiry"
                           Style="{StaticResource FieldLabel}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource WarningAmberBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Message — separate TextBlocks for controlled line spacing -->
            <TextBlock x:Name="LegLine"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="FallsLine"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
            <TextBlock x:Name="ChooseLine"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,12,0,20"/>

            <!-- Buttons -->
            <UniformGrid Columns="3">
                <Button Content="◀  Previous"
                        Style="{StaticResource TradingButton}"
                        Margin="0,0,6,0"
                        Click="Previous_Click"
                        ToolTip="Roll to previous business day (Friday)"/>
                <Button Content="Next  ▶"
                        Style="{StaticResource TradingButton}"
                        Margin="3,0,3,0"
                        Click="Next_Click"
                        ToolTip="Roll to next business day (Monday)"/>
                <Button Content="Keep"
                        Style="{StaticResource TradingButton}"
                        Margin="6,0,0,0"
                        Foreground="{StaticResource WarningAmberBrush}"
                        Click="Cancel_Click"
                        ToolTip="Keep weekend date (not bookable)"/>
            </UniformGrid>

        </StackPanel>
    </Border>
</Window>