<UserControl x:Class="FxTradeConfirmation.Views.TradeGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

	<Grid x:Name="RootGrid" Margin="0">
		<!-- Columns are built dynamically in code-behind:
             Col 0 = Row labels
             Col 1 = Distributor inputs
             Col 2..N = One per Leg (each with header + add/remove buttons)
        -->
	</Grid>
</UserControl>