<Window x:Class="FxTradeConfirmation.Views.SolvingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Premium Solving" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource AccentBlueBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel>
            <!-- Header: "Solve Premium [SEK pips]" or "Solve Premium Amount [SEK]" -->
            <DockPanel Margin="0,0,0,4">
                <Button Content="✕" DockPanel.Dock="Right"
                        Style="{StaticResource IconButton}"
                        Foreground="{StaticResource NegativeRedBrush}"
                        Click="Cancel_Click" ToolTip="Cancel (Esc)"
                        VerticalAlignment="Top"/>
                <TextBlock x:Name="TitleLabel"
                           Text="Solve Premium"
                           Style="{StaticResource FieldLabel}"
                           FontSize="14" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Context label, e.g. "Leg 2 – Call – Premium" -->
            <TextBlock x:Name="ContextLabel"
                       FontSize="12" FontFamily="{StaticResource MonoFont}"
                       Foreground="{StaticResource SolvingAmberBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>

            <!-- Unit subtitle, e.g. "[SEK pips]" -->
            <TextBlock x:Name="UnitLabel"
                       FontSize="11" FontFamily="{StaticResource MonoFont}"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,10"/>

            <TextBlock Text="TOTAL TARGET VALUE" Style="{StaticResource FieldLabel}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TargetAmountBox" Style="{StaticResource TradingTextBox}"
                     FontSize="16" Margin="0,0,0,16"
                     PreviewTextInput="TargetAmountBox_PreviewTextInput"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="PAY" Style="{StaticResource DangerButton}"
                        Click="Pay_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="ZERO" Style="{StaticResource TradingButton}"
                        Click="Zero_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="RECEIVE" Style="{StaticResource SuccessButton}"
                        Click="Receive_Click" Width="80"/>
            </StackPanel>

            <!-- Error message — below buttons, hidden by default -->
            <TextBlock x:Name="ErrorMessage"
                       Foreground="{StaticResource NegativeRedBrush}"
                       FontSize="11" FontFamily="{StaticResource MonoFont}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>