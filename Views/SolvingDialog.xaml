<Window x:Class="FxTradeConfirmation.Views.SolvingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Premium Solving" Width="320" Height="200"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource AccentBlueBrush}"
            BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel>
            <TextBlock Text="Total Premium Target" Style="{StaticResource FieldLabel}"
                       FontSize="14" Margin="0,0,0,12"/>

            <TextBox x:Name="TargetAmountBox" Style="{StaticResource TradingTextBox}"
                     FontSize="16" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="PAY" Style="{StaticResource DangerButton}"
                        Click="Pay_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="ZERO" Style="{StaticResource TradingButton}"
                        Click="Zero_Click" Width="80" Margin="0,0,8,0"/>
                <Button Content="RECEIVE" Style="{StaticResource SuccessButton}"
                        Click="Receive_Click" Width="80"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
