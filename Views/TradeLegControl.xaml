<UserControl x:Class="FxTradeConfirmation.Views.TradeLegControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:FxTradeConfirmation.Models"
             mc:Ignorable="d"
             MinWidth="220" MaxWidth="280">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="HedgeTypeValues" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:HedgeType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="1" CornerRadius="8"
            Margin="4" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- === LEG HEADER === -->
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{Binding LegNumber, StringFormat='Leg {0}'}"
                           Style="{StaticResource LegHeader}" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="+" ToolTip="Copy Leg" Style="{StaticResource IconButton}"
                            Command="{Binding DataContext.CopyLegCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Foreground="{StaticResource PositiveGreenBrush}"/>
                    <Button Content="✕" ToolTip="Delete Leg" Style="{StaticResource IconButton}"
                            Command="{Binding DataContext.DeleteLegCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Foreground="{StaticResource NegativeRedBrush}" Margin="4,0,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SECTION 1: TRADE DETAILS                        -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="1" BorderBrush="{StaticResource BorderSectionBrush}"
                    BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="0,2,0,0" Opacity="0.7" Margin="0,0,0,6"/>
                    <TextBlock Text="📋  TRADE DETAILS" Style="{StaticResource SectionHeader}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="COUNTERPART" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource TradingComboBox}"
                              Text="{Binding Counterpart, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding DataContext.ReferenceData.Counterparts,
                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              Margin="0,0,0,6"/>

                    <TextBlock Text="CURRENCY PAIR" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource TradingComboBox}"
                              Text="{Binding CurrencyPair, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding DataContext.ReferenceData.CurrencyPairs,
                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              Margin="0,0,0,6"/>

                    <TextBlock Text="CLIENT BUY/SELL" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0"
                                     GroupName="{Binding LegNumber, StringFormat='bs_{0}'}"
                                     IsChecked="{Binding BuySell, Converter={StaticResource EnumToBool}, ConverterParameter=Buy}"
                                     Style="{StaticResource SegmentedToggleBuy}"
                                     Content="BUY"/>
                        <RadioButton Grid.Column="1"
                                     GroupName="{Binding LegNumber, StringFormat='bs_{0}'}"
                                     IsChecked="{Binding BuySell, Converter={StaticResource EnumToBool}, ConverterParameter=Sell}"
                                     Style="{StaticResource SegmentedToggleSell}"
                                     Content="SELL"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SECTION 2: OPTION DETAILS                       -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderSectionBrush}"
                    BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="0,2,0,0" Opacity="0.7" Margin="0,0,0,6"/>
                    <TextBlock Text="📊  OPTION DETAILS" Style="{StaticResource SectionHeader}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="CALL/PUT" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0"
                                     GroupName="{Binding LegNumber, StringFormat='cp_{0}'}"
                                     IsChecked="{Binding CallPut, Converter={StaticResource EnumToBool}, ConverterParameter=Call}"
                                     Style="{StaticResource SegmentedToggleLeft}"
                                     Content="CALL"/>
                        <RadioButton Grid.Column="1"
                                     GroupName="{Binding LegNumber, StringFormat='cp_{0}'}"
                                     IsChecked="{Binding CallPut, Converter={StaticResource EnumToBool}, ConverterParameter=Put}"
                                     Style="{StaticResource SegmentedToggleRight}"
                                     Content="PUT"/>
                    </Grid>

                    <!-- Strike -->
                    <TextBlock Text="STRIKE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding StrikeText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="StrikeBox_PreviewTextInput"
                             LostFocus="StrikeBox_LostFocus"
                             KeyDown="StrikeBox_KeyDown"
                             Margin="0,0,0,6"/>

                    <!-- Expiry Date -->
                    <TextBlock Text="EXPIRY DATE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding ExpiryText, UpdateSourceTrigger=PropertyChanged}"
                             LostFocus="ExpiryBox_LostFocus"
                             KeyDown="ExpiryBox_KeyDown"
                             Margin="0,0,0,6"/>

                    <!-- Settlement Date (Read-only) -->
                    <TextBlock Text="SETTLEMENT DATE" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}" IsReadOnly="True"
                             Text="{Binding SettlementDate, StringFormat='yyyy-MM-dd', Mode=OneWay}"
                             Margin="0,0,0,6"/>

                    <!-- Cut -->
                    <TextBlock Text="CUT" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Style="{StaticResource TradingComboBox}"
                              Text="{Binding Cut, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding DataContext.ReferenceData.Cuts,
                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              Margin="0,0,0,6"/>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SECTION 3: AMOUNTS & PREMIUM                   -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="3" BorderBrush="{StaticResource BorderSectionBrush}"
                    BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,8">
                <StackPanel>
                    <Border BorderBrush="{StaticResource AccentBlueBrush}"
                            BorderThickness="0,2,0,0" Opacity="0.7" Margin="0,0,0,6"/>
                    <TextBlock Text="💰  AMOUNTS &amp; PREMIUM" Style="{StaticResource SectionHeader}"
                               Margin="0,0,0,8"/>

                    <!-- Notional -->
                    <TextBlock Text="NOTIONAL" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBoxWithSuffix}"
                             Text="{Binding NotionalText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="NotionalBox_PreviewTextInput"
                             LostFocus="NotionalBox_LostFocus"
                             KeyDown="NotionalBox_KeyDown"
                             Margin="0,0,0,6">
                        <TextBox.Tag>
                            <Button Content="{Binding NotionalCurrency}"
                                    Style="{StaticResource InlineSuffixToggle}"
                                    Command="{Binding ToggleNotionalCurrencyCommand}"/>
                        </TextBox.Tag>
                    </TextBox>

                    <!-- Premium -->
                    <TextBlock Text="PREMIUM" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBoxWithSuffix}"
                             Text="{Binding PremiumText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding PremiumInputEnabled}"
                             PreviewTextInput="PremiumBox_PreviewTextInput"
                             LostFocus="PremiumBox_LostFocus"
                             KeyDown="PremiumBox_KeyDown"
                             Margin="0,0,0,6">
                        <TextBox.Tag>
                            <Button Content="{Binding PremiumStyleDisplay}"
                                    Style="{StaticResource InlineSuffixToggle}"
                                    Command="{Binding TogglePremiumStyleCommand}"/>
                        </TextBox.Tag>
                    </TextBox>

                    <!-- Premium Amount -->
                    <TextBlock Text="PREMIUM AMOUNT" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBoxWithSuffix}"
                             Text="{Binding PremiumAmountText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding PremiumInputEnabled}"
                             IsReadOnly="{Binding IsPremiumLocked}"
                             PreviewTextInput="PremiumAmountBox_PreviewTextInput"
                             LostFocus="PremiumAmountBox_LostFocus"
                             KeyDown="PremiumAmountBox_KeyDown"
                             Margin="0,0,0,6">
                        <TextBox.Tag>
                            <Button Content="{Binding PremiumCurrency}"
                                    Style="{StaticResource InlineSuffixToggle}"
                                    Command="{Binding TogglePremiumCurrencyCommand}"/>
                        </TextBox.Tag>
                    </TextBox>

                    <!-- Premium Date -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="PREMIUM DATE" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left"/>
                        <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Style="{StaticResource PremiumBadge}">
                            <TextBlock FontSize="9" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="{Binding PremiumDateType, Mode=OneWay}"/>
                        </Border>
                    </DockPanel>
                    <TextBox Style="{StaticResource TradingTextBox}" IsReadOnly="True"
                             Text="{Binding PremiumDate, StringFormat='yyyy-MM-dd', Mode=OneWay}"
                             Margin="0,0,0,6"/>
                </StackPanel>
            </Border>

            <!-- === ADMIN FIELDS === -->
            <StackPanel Grid.Row="4"
                        Visibility="{Binding DataContext.ShowAdminRows,
                            RelativeSource={RelativeSource AncestorType=ItemsControl},
                            Converter={StaticResource BoolToVis}}">

                <Border BorderBrush="{StaticResource AccentBlueBrush}"
                        BorderThickness="0,2,0,0" Opacity="0.7" Margin="0,0,0,6"/>
                <TextBlock Text="⚙  ADMIN" Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,8"/>

                <TextBlock Text="PORTFOLIO MX3" Style="{StaticResource FieldLabel}"/>
                <ComboBox Style="{StaticResource TradingComboBox}"
                          Text="{Binding PortfolioMX3, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.ReferenceData.Portfolios,
                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          Margin="0,0,0,6"/>

                <TextBlock Text="TRADER" Style="{StaticResource FieldLabel}"/>
                <ComboBox Style="{StaticResource TradingComboBox}"
                          Text="{Binding Trader, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.ReferenceData.Traders,
                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          Margin="0,0,0,6"/>

                <TextBlock Text="EXECUTION TIME" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}" IsReadOnly="True"
                         Text="{Binding ExecutionTime, Mode=OneWay}" Margin="0,0,0,6"/>

                <TextBlock Text="MIC" Style="{StaticResource FieldLabel}"/>
                <ComboBox Style="{StaticResource TradingComboBox}"
                          Text="{Binding Mic, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.ReferenceData.MICs,
                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          Margin="0,0,0,6"/>

                <TextBlock Text="TVTIC" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding Tvtic, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                <TextBlock Text="ISIN" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding Isin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                <TextBlock Text="SALES" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding Sales, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                <TextBlock Text="INV DECISION ID" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding InvestmentDecisionID, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"/>

                <TextBlock Text="BROKER" Style="{StaticResource FieldLabel}"/>
                <ComboBox Style="{StaticResource TradingComboBox}"
                          Text="{Binding Broker, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DataContext.ReferenceData.Brokers,
                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          Margin="0,0,0,6"/>

                <TextBlock Text="MARGIN" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding MarginText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"/>

                <TextBlock Text="REPORTING ENTITY" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding ReportingEntity, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"/>
            </StackPanel>

            <!-- === HEDGE SECTION === -->
            <Border Grid.Row="5" Margin="0,4,0,0"
                    BorderBrush="{StaticResource AccentBlueBrush}"
                    BorderThickness="0,2,0,0"
                    Opacity="0.7"/>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <TextBlock Text="⛊  HEDGE" Style="{StaticResource SectionHeader}"
                           Margin="0,0,0,4"/>
                <ComboBox Style="{StaticResource TradingComboBox}" IsEditable="False"
                          SelectedItem="{Binding Hedge}"
                          ItemsSource="{Binding Source={StaticResource HedgeTypeValues}}"
                          Margin="0,0,0,6"/>
            </StackPanel>

            <!-- === HEDGE DETAIL FIELDS === -->
            <StackPanel Grid.Row="6"
                        Visibility="{Binding HasHedge, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="CLIENT BUY/SELL" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}" IsReadOnly="True"
                         Text="{Binding HedgeBuySell, Mode=OneWay}" Margin="0,0,0,6"/>

                <TextBlock Text="NOTIONAL" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                         Text="{Binding HedgeNotionalText, UpdateSourceTrigger=PropertyChanged}"
                         PreviewTextInput="HedgeNotionalBox_PreviewTextInput"
                         LostFocus="HedgeNotionalBox_LostFocus"
                         KeyDown="HedgeNotionalBox_KeyDown"
                         Margin="0,0,0,6"/>

                <TextBlock Text="NOTIONAL CURRENCY" Style="{StaticResource FieldLabel}"/>
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="12"
                           Foreground="{StaticResource AccentBlueBrush}"
                           Text="{Binding HedgeNotionalCurrency}" Margin="0,0,0,6"/>

                <!-- Hedge Rate -->
                <TextBlock Text="HEDGE RATE" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding HedgeRateText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="HedgeRateBox_PreviewTextInput"
                             LostFocus="HedgeRateBox_LostFocus"
                             KeyDown="HedgeRateBox_KeyDown"
                             Margin="0,0,0,6"/>

                <TextBlock Text="SETTLEMENT DATE" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource TradingTextBox}" IsReadOnly="True"
                         Text="{Binding HedgeSettlementDate, StringFormat='yyyy-MM-dd', Mode=OneWay}"
                         Margin="0,0,0,6"/>

                <StackPanel Visibility="{Binding DataContext.ShowAdminRows,
                    RelativeSource={RelativeSource AncestorType=ItemsControl},
                    Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="TVTIC" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding HedgeTVTIC, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Text="UTI" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding HedgeUTI, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Text="ISIN" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding HedgeISIN, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Text="BOOK CALYPSO" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource TradingTextBox}"
                             Text="{Binding BookCalypso, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>