<Window x:Class="FxTradeConfirmation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FxTradeConfirmation.Views"
        xmlns:conv="clr-namespace:FxTradeConfirmation.Converters"
        mc:Ignorable="d"
        Title="FX Trade Confirmation"
        SizeToContent="WidthAndHeight"
        MinWidth="586" MinHeight="400"
        WindowState="Normal"
        WindowStyle="None"
        Background="{StaticResource BgDarkestBrush}">

    <Window.Resources>
        <conv:PremiumColorConverter x:Key="PremiumColor"/>

        <!-- Window control button -->
        <Style x:Key="WindowChromeButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button (red hover) -->
        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B31019"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- === TITLE BAR === -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel Height="36">
                <!-- Window buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Style="{StaticResource WindowChromeButton}" Click="MinimizeButton_Click">
                        <Path Data="M0,5 H10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource WindowChromeButton}" Click="MaximizeButton_Click">
                        <Path x:Name="MaximizeIcon" Data="M0,0 H10 V10 H0 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Fill="Transparent"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1"/>
                    </Button>
                </StackPanel>

                <!-- Title (left, fills remaining space) -->
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="4" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2DD4BF" Offset="0.0"/>
                                <GradientStop Color="#2563EB" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="FX" FontSize="8" FontWeight="Bold"
                                   Foreground="#0F172A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MainFont}"
                               VerticalAlignment="Center">
                        <Run Text="FX" Foreground="{StaticResource AccentBlueBrush}"/>
                        <Run Text=" Trade Confirmation"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === TOOLBAR === -->
        <Border Grid.Row="1" Background="{StaticResource BgDarkBrush}"
                Padding="8,4" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                MaxWidth="{Binding ActualWidth, ElementName=GridScrollViewer}">
            <DockPanel>
                <!-- Right-aligned primary actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarPrimaryButton}"
                            Command="{Binding SaveCommand}" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left-aligned secondary actions -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding AddLegCommand}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="13" Margin="0,0,4,0"
                                       Foreground="{StaticResource PositiveGreenBrush}"/>
                            <TextBlock Text="Add Leg"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarDangerButton}"
                            Command="{Binding ClearAllCommand}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="10" Margin="0,0,4,0"/>
                            <TextBlock Text="Clear All"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="8,2"/>

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding SendMailCommand}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Mail"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="8,2"/>

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleAdminRowsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Admin"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === MAIN GRID AREA === -->
        <ScrollViewer x:Name="GridScrollViewer" Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="0,0,0,8">
            <views:TradeGridControl DataContext="{Binding}"/>
        </ScrollViewer>

        <!-- === TOTAL PREMIUM BAR === -->
        <Border Grid.Row="3" Background="{StaticResource BgDarkBrush}"
                Padding="16,8" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding HasMultipleLegs, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <TextBlock Text="TOTAL PREMIUM" Style="{StaticResource FieldLabel}"
                           DockPanel.Dock="Left" FontWeight="Bold" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                           FontFamily="{StaticResource MonoFont}" FontSize="16"
                           FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{Binding TotalPremium, Converter={StaticResource PremiumColor}}"
                           Text="{Binding TotalPremiumDisplay}"/>
            </DockPanel>
        </Border>

        <!-- === STATUS BAR === -->
        <Border Grid.Row="4" Background="{StaticResource BgDarkBrush}"
                Padding="16,6" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Style="{StaticResource ConnectionDot}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectionText}}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>