<Window x:Class="FxTradeConfirmation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FxTradeConfirmation.Views"
        xmlns:conv="clr-namespace:FxTradeConfirmation.Converters"
        mc:Ignorable="d"
        Title="FX Trade Confirmation"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        WindowState="Normal" Background="{StaticResource BgDarkestBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:PremiumColorConverter x:Key="PremiumColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- === CUSTOM WINDOW CHROME TITLE BAR === -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Window caption buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            Click="OnMinimize">
                        <Path Data="M 0 0 H 10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            Click="OnMaximizeRestore">
                        <Path x:Name="MaximizeIcon"
                              Data="M 0 0 H 10 V 10 H 0 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Fill="Transparent"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButton}"
                            Click="OnClose">
                        <Path Data="M 0 0 L 10 10 M 0 10 L 10 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Window icon + title (left, draggable area) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="/Assets/app-icon.png" Width="16" Height="16"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource MainFont}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === TITLE BAR === -->
        <Border Grid.Row="1" Background="{StaticResource BgDarkBrush}"
                Padding="16,10" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MainFont}">
                <Run Text="FX" Foreground="{StaticResource AccentBlueBrush}"/>
                <Run Text=" Trade Confirmation"/>
            </TextBlock>
        </Border>

        <!-- === TOOLBAR === -->
        <Border Grid.Row="2" Background="{StaticResource BgDarkBrush}"
                Padding="8,4" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                MaxWidth="{Binding ActualWidth, ElementName=GridScrollViewer}">
            <DockPanel>
                <!-- Right-aligned primary actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarPrimaryButton}"
                            Command="{Binding SaveCommand}" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left-aligned secondary actions -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding AddLegCommand}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="13" Margin="0,0,4,0"
                                       Foreground="{StaticResource PositiveGreenBrush}"/>
                            <TextBlock Text="Add Leg"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarDangerButton}"
                            Command="{Binding ClearAllCommand}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="10" Margin="0,0,4,0"/>
                            <TextBlock Text="Clear All"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="8,2"/>

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding SendMailCommand}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Mail"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}"
                            Margin="8,2"/>

                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleAdminRowsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="Admin"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === MAIN GRID AREA === -->
        <ScrollViewer x:Name="GridScrollViewer" Grid.Row="3"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Margin="0,0,0,8">
            <views:TradeGridControl DataContext="{Binding}"/>
        </ScrollViewer>

        <!-- === TOTAL PREMIUM BAR === -->
        <Border Grid.Row="4" Background="{StaticResource BgDarkBrush}"
                Padding="16,8" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding HasMultipleLegs, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <TextBlock Text="TOTAL PREMIUM" Style="{StaticResource FieldLabel}"
                           DockPanel.Dock="Left" FontWeight="Bold" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                           FontFamily="{StaticResource MonoFont}" FontSize="16"
                           FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{Binding TotalPremium, Converter={StaticResource PremiumColor}}"
                           Text="{Binding TotalPremiumDisplay}"/>
            </DockPanel>
        </Border>

        <!-- === STATUS BAR === -->
        <Border Grid.Row="5" Background="{StaticResource BgDarkBrush}"
                Padding="16,6" BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Style="{StaticResource ConnectionDot}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectionText}}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>